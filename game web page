.bg-container {
    background-image: url(https://d2clawv67efefq.cloudfront.net/ccbp-static-website/arvrbg.png);
    background-size: cover;
    height: 100vh;
}

.advanced-technologies-card {
    background-color: #ffffff;
    border-top-left-radius: 16px;
    border-top-right-radius: 16px;
    padding: 25px;
}

.advanced-technologies-title {
    color: #5752ab;
    font-family: "Bree Serif";
    font-size: 24px;
}

.advanced-technologies-description {
    color: #323f4b;
    font-family: "Roboto";
}

.learn-more-button {
    color: #171f46;
    background-color: #ffffff;
    font-family: "Roboto";
    font-size: 12px;
    font-weight: 500;
    width: 126px;
    height: 38px;
    border-style: solid;
    border-color: #d7dfe9;
    border-radius: 8px;
    border-width: 8px;
    margin-right: 5px;

}

.save-draft-button {
    color: #ffffff;
    background-color: #5752ab;
    font-family: "Roboto";
    font-size: 12px;
    font-weight: 500;
    width: 126px;
    height: 38px;
    border-width: 0px;
    border-radius: 8px;
    margin-left: 5px;
}
